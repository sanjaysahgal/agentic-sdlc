# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_APP_TOKEN=xapp-...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Product
PRODUCT_NAME=YourProductName
SLACK_MAIN_CHANNEL=general

# GitHub — customer repo (specs, code)
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=your-github-org
GITHUB_REPO=your-repo-name

# GitHub — platform repo (eval feedback, reaction logs live here, not in the customer repo)
PLATFORM_GITHUB_OWNER=your-github-org
PLATFORM_GITHUB_REPO=agentic-sdlc

# Role mapping — Slack user IDs for the Orchestrator to mention in alerts
# Find a user's ID in Slack: click their profile → "..." → Copy member ID
# SLACK_PM_USER=U0123456789
# SLACK_DESIGNER_USER=U0123456789
# SLACK_ARCHITECT_USER=U0123456789

# Optional — override default spec paths if your repo uses a different structure
# PATH_PRODUCT_VISION=specs/product/PRODUCT_VISION.md
# PATH_SYSTEM_ARCHITECTURE=specs/architecture/system-architecture.md
# PATH_DESIGN_SYSTEM=specs/design/DESIGN_SYSTEM.md
# PATH_FEATURE_CONVENTIONS=specs/features/CLAUDE.md
# PATH_FEATURES_ROOT=specs/features
